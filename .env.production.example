# Production env — copy to .env.production on the droplet and fill in.
# DO NOT COMMIT REAL VALUES. The droplet keeps these out of the repo via .gitignore.

APP_ENV=production
APP_NAME=ifa-backtest-product
API_PREFIX=/api/v1

# ── Supabase (use NEW rotated keys, not the ones from earlier in chat) ──
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_REST_URL=https://<project-ref>.supabase.co/rest/v1/
SUPABASE_ANON_KEY=<new-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<new-service-role-key>
SUPABASE_PUBLISHABLE_KEY=<new-publishable-key>
SUPABASE_SECRET_KEY=<new-secret-key>
SUPABASE_BUCKET=ifa-private

DATABASE_URL=postgresql+asyncpg://postgres:<new-password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:<new-password>@db.<project-ref>.supabase.co:5432/postgres

# ── Firebase Admin (rotated service account JSON sits at backend/secrets/firebase-admin.json) ──
FIREBASE_PROJECT_ID=ifa-backtest-product
FIREBASE_CREDENTIALS_PATH=./backend/secrets/firebase-admin.json

# ── Firebase Web (frontend build-time) ──
VITE_FIREBASE_API_KEY=<web-api-key>
VITE_FIREBASE_AUTH_DOMAIN=ifa-backtest-product.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ifa-backtest-product
VITE_FIREBASE_STORAGE_BUCKET=ifa-backtest-product.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=<sender-id>
VITE_FIREBASE_APP_ID=<app-id>

# Production main admin login
MAIN_ADMIN_EMAIL=insightfusionanalytics@gmail.com
MAIN_ADMIN_INITIAL_PASSWORD=<NEW-strong-password>

# Frontend hits the same host as the backend, just on /api/v1
VITE_API_BASE_URL=https://backtestingengine.insightfusionanalytics.com/api/v1

# Sentry (optional, recommended for prod)
SENTRY_DSN_BACKEND=
VITE_SENTRY_DSN_FRONTEND=
