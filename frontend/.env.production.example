# Frontend production env — set these in the Vercel project's
# Environment Variables UI (Project > Settings > Environment Variables).
# Vite reads VITE_* values from process.env at build time, so no .env
# file needs to exist on Vercel.

# Where the frontend sends API calls. Set to the live Render service URL.
VITE_API_BASE_URL=https://ifa-backtest-backend.onrender.com/api/v1

# Firebase Web SDK — these are public, but rotate them in Firebase
# console if they were ever pasted in chat / public channels.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=ifa-backtest-product.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ifa-backtest-product
VITE_FIREBASE_STORAGE_BUCKET=ifa-backtest-product.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Sentry frontend DSN
VITE_SENTRY_DSN_FRONTEND=
