# Copy to .env and fill in values

APP_ENV=local
APP_NAME=ifa-backtest-product
API_PREFIX=/api/v1

# ── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_REST_URL=https://<project-ref>.supabase.co/rest/v1/
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_BUCKET=ifa-private

DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Firebase Admin ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=./backend/secrets/firebase-admin.json

# ── Firebase Web (frontend) ────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=<project-id>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=<project-id>.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Main admin (provisioned by seed script) ────────────────────
MAIN_ADMIN_EMAIL=
MAIN_ADMIN_INITIAL_PASSWORD=

# ── Frontend ───────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── Sentry (optional) ──────────────────────────────────────────
SENTRY_DSN_BACKEND=
VITE_SENTRY_DSN_FRONTEND=
